{
  "name": "Resourced",
  "version": "1.0.0",
  "description": "Take complete control over any website by rerouting requests and replacing, modifying, or injecting any resource.",
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16x16.png"
    },
    "default_popup": "index.html"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "src/extension/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "src/inject/scriptInjector.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-disabled-16x16.png",
        "icons/icon-disabled-48x48.png",
        "icons/icon-disabled-128x128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "manifest_version": 3
}
