{
  "name": "Resource Override Next",
  "version": "2.0.0",
  "description": "An extension to help you gain full control of any website by redirecting traffic, replacing, editing, or inserting new content.",
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16x16.png"
    }
  },
  "devtools_page": "src/ui/devtools.html",
  "options_ui": {
    "page": "index.html"
  },
  "background": {
    "service_worker": "src/extension/background.js",
    "type": "module"
  },
  "content_scripts": [{
      "matches" : ["*://*/*"],
      "js": ["src/inject/scriptInjector.js"],
      "all_frames": true,
      "run_at": "document_start"
  }],
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": ["*://*/*"],
  "manifest_version": 3
}